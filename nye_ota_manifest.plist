<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
"http://www.apple.com/DTDs/PropertyList-1.0.dtd">

<plist version="1.0">
<dict>
  <key>items</key>
  <array>
    <dict>

      <key>assets</key>
      <array>
        <dict>
          <key>kind</key>
          <string>software-package</string>

          <!-- REQUIRED: REPLACE WITH YOUR IPA HTTPS URL -->
          <key>url</key>
          <string>https://YOUR-DOMAIN.com/YOUR-APP.ipa</string>

        </dict>
      </array>

      <key>metadata</key>
      <dict>

        <!-- REQUIRED: REPLACE WITH YOUR BUNDLE IDENTIFIER -->
        <key>bundle-identifier</key>
        <string>COM.YOUR.COMPANY.APP</string>

        <!-- REQUIRED: REPLACE WITH YOUR APP VERSION -->
        <key>bundle-version</key>
        <string>1.0.0</string>

        <key>kind</key>
        <string>software</string>

        <!-- REQUIRED: REPLACE WITH YOUR APP NAME -->
        <key>title</key>
        <string>YOUR APP NAME</string>

      </dict>

    </dict>
  </array>
</dict>
</plist>
